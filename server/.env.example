# Dùng App Password (không phải mật khẩu Gmail thường)
# Tạo tại: https://myaccount.google.com/apppasswords
MAIL_USER=taxeasy.vn@gmail.com
MAIL_PASS=your_gmail_app_password_here

# Claude AI — gợi ý thông minh (GET /ai/insights)
